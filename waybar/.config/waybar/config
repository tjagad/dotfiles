    ]
  },
  "pulseaudio": {
    "format": "<span size='large' font_family='JetBrainsMono Nerd Font Mono'>{icon}</span> {volume}%",
    "format-bluetooth": "<span size='large' font_family='JetBrainsMono Nerd Font Mono'>{icon}´èö</span> {volume}%",
    "format-bluetooth-muted": "¯╗¿ {icon}´èö",
    "format-muted": "¯╗¿",
